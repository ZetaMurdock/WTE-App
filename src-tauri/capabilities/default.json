{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core, updater and process permissions for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "process:allow-restart",
    "process:allow-exit",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-watch",
    "fs:allow-unwatch",
    "sql:default",
    "sql:allow-execute"
  ]
}
