{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "W.T.E",
  "version": "0.8.25",
  "identifier": "com.wte.tabletop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "W.T.E — Character Sheet + VTT",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../src/rules/*"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ZetaMurdock/WTE-App/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3Mzk1ODNBNUZFRjAyOTIKUldTU0F1OWZPbGc1NXdUZ2tFSFg0eGFRejBYZjNVc1kzRkVOSFhWZk4zd3RkZWJFSkRQeHB0ZmEK"
    }
  }
}
